{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ConsoleSupportForS3",
            "Effect": "Allow",
            "Action": [
                "s3:ListAllMyBuckets",
                "s3:GetBucketLocation"
            ],
            "Resource": "*"
        },
        {
            "Sid": "ListLabBucket",
            "Effect": "Allow",
            "Action": "s3:ListBucket",
            "Resource": "arn:aws:s3:::minisec-iam-lab-nhatminh-2026"
        },
        {
            "Sid": "ReadWriteDevFolderOnly",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject"
            ],
            "Resource": "arn:aws:s3:::minisec-iam-lab-nhatminh-2026/dev/*"
        },
        {
            "Sid": "DenyDangerousS3Actions",
            "Effect": "Deny",
            "Action": [
                "s3:DeleteObject",
                "s3:DeleteBucket",
                "s3:PutBucketPolicy",
                "s3:DeleteBucketPolicy",
                "s3:PutBucketPublicAccessBlock",
                "s3:PutBucketAcl",
                "s3:PutObjectAcl"
            ],
            "Resource": [
                "arn:aws:s3:::minisec-iam-lab-nhatminh-2026",
                "arn:aws:s3:::minisec-iam-lab-nhatminh-2026/*"
            ]
        }
    ]
}